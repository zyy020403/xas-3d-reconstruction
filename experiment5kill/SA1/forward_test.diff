+    if not (head_ce.dim() == 0):
+        fail("Phase 6.6.b", f"loss_type_ce_head not scalar: dim={head_ce.dim()}")
+
+    # 6.6.c — center_Z conditioning effective on head
+    log("--- 6.6.c center_Z=true vs 0 → head_logits differ ≥ 5/20 ranks ---")
+    with torch.no_grad():
