+    if tuple(head_logits.shape) != (4, 20, 100):
+        fail("Phase 6.6.a", f"head_logits shape {tuple(head_logits.shape)} != (4, 20, 100)")
+
+    # 6.6.b — loss_type_ce_head finite scalar
